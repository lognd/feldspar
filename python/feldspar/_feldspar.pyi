    @staticmethod
    def _new_checked(lo: float, hi: float) -> Interval: ...
    @staticmethod
    def _point_checked(x: float) -> Interval: ...
    # Monkey-patched onto this class by feldspar/core.py at import time
    # (01-interfaces `Interval.new`/`Interval.point`); declared here, not
    # reimplemented, so `ty` type-checks core.py's own patch-site
    # assignments and every downstream caller against one signature.
    @staticmethod
    def new(lo: float, hi: float) -> Result[Interval, Any]: ...
    @staticmethod
    def point(x: float) -> Result[Interval, Any]: ...
    @property
    def lo(self) -> float: ...
    @property
    def hi(self) -> float: ...
    def width(self) -> float: ...
    def half_width(self) -> float: ...
    def midpoint(self) -> float: ...
    def contains(self, x: float) -> bool: ...
    def is_subset(self, outer: Interval) -> bool: ...
    def hull(self, other: Interval) -> Interval: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

